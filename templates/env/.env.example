# ══════════════════════════════════════════════════════════════════
#  Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env — only .env.example
# ══════════════════════════════════════════════════════════════════

# Application
# APP_ENV=development
# APP_PORT=3000

# Database
# DATABASE_URL=

# API Keys
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Auth
# JWT_SECRET=
# SESSION_SECRET=
