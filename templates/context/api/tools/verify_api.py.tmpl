#!/usr/bin/env python3
"""{{PROJECT_NAME}} API verification checks.

Scans source files to verify that code adheres to project rules
defined in directives/SOP.md.

Exit codes:
    0 — All checks pass
    1 — One or more checks failed
"""

import os
import re
import sys

PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))


def scan_files(directory, extensions=(".py", ".ts", ".js", ".go", ".rs")):
    """Yield all files with given extensions in directory recursively."""
    for root, _dirs, files in os.walk(directory):
        if "node_modules" in root or "__pycache__" in root or ".venv" in root or "dist" in root or "vendor" in root:
            continue
        for f in files:
            if any(f.endswith(ext) for ext in extensions):
                yield os.path.join(root, f)


def check_no_hardcoded_secrets():
    """Ensure no hardcoded API keys or secrets in source files."""
    secret_patterns = [
        (r'["\']sk-[a-zA-Z0-9]{20,}["\']', "OpenAI API key"),
        (r'["\']ghp_[a-zA-Z0-9]{36,}["\']', "GitHub personal access token"),
        (r'["\']Bearer\s+[a-zA-Z0-9._-]{20,}["\']', "Hardcoded Bearer token"),
        (r'password\s*[:=]\s*["\'][^"\']{8,}["\']', "Hardcoded password"),
        (r'["\']AKIA[A-Z0-9]{16}["\']', "AWS access key"),
    ]

    violations = []
    for filepath in scan_files(PROJECT_ROOT):
        if "test" in os.path.basename(filepath).lower():
            continue
        try:
            with open(filepath, encoding="utf-8") as f:
                content = f.read()
        except (OSError, UnicodeDecodeError):
            continue
        for pattern, desc in secret_patterns:
            matches = re.findall(pattern, content)
            for match in matches:
                rel_path = os.path.relpath(filepath, PROJECT_ROOT)
                violations.append(f"{rel_path}: {desc} found")

    if violations:
        detail = "; ".join(violations[:3])
        if len(violations) > 3:
            detail += f" (+{len(violations) - 3} more)"
        return ("No hardcoded secrets in source", False, detail)
    return ("No hardcoded secrets in source", True, None)


def check_no_sql_injection():
    """Check for potential SQL injection patterns."""
    sql_patterns = [
        (r'f["\'].*SELECT.*\{', "f-string in SQL query"),
        (r'f["\'].*INSERT.*\{', "f-string in SQL query"),
        (r'f["\'].*UPDATE.*\{', "f-string in SQL query"),
        (r'f["\'].*DELETE.*\{', "f-string in SQL query"),
        (r'["\'].*SELECT.*["\']\s*\+\s*', "String concatenation in SQL"),
        (r'["\'].*INSERT.*["\']\s*\+\s*', "String concatenation in SQL"),
        (r'`.*SELECT.*\$\{', "Template literal in SQL query"),
        (r'`.*INSERT.*\$\{', "Template literal in SQL query"),
    ]

    violations = []
    for filepath in scan_files(PROJECT_ROOT):
        if "test" in os.path.basename(filepath).lower() or "migration" in filepath.lower():
            continue
        try:
            with open(filepath, encoding="utf-8") as f:
                content = f.read()
        except (OSError, UnicodeDecodeError):
            continue
        for pattern, desc in sql_patterns:
            if re.search(pattern, content, re.IGNORECASE):
                rel_path = os.path.relpath(filepath, PROJECT_ROOT)
                violations.append(f"{rel_path}: {desc}")

    if violations:
        detail = "; ".join(violations[:3])
        return ("No SQL injection patterns", False, detail)
    return ("No SQL injection patterns", True, None)


def check_input_validation():
    """Check that route handlers have input validation."""
    # Heuristic: look for common validation library imports
    has_validation = False
    validation_indicators = [
        "from pydantic", "import pydantic",  # Python
        "from marshmallow", "import marshmallow",  # Python
        "zod", "yup", "joi",  # JavaScript/TypeScript
        "validator",  # General
    ]

    for filepath in scan_files(PROJECT_ROOT):
        try:
            with open(filepath, encoding="utf-8") as f:
                content = f.read()
        except (OSError, UnicodeDecodeError):
            continue
        for indicator in validation_indicators:
            if indicator in content:
                has_validation = True
                break
        if has_validation:
            break

    if not has_validation:
        return ("Input validation library present", False, "No validation library detected (pydantic, zod, joi, etc.)")
    return ("Input validation library present", True, None)


def check_cors_not_wildcard():
    """Ensure CORS is not set to wildcard in production code."""
    violations = []
    for filepath in scan_files(PROJECT_ROOT):
        basename = os.path.basename(filepath).lower()
        if "test" in basename or "verify" in basename:
            continue
        try:
            with open(filepath, encoding="utf-8") as f:
                content = f.read()
        except (OSError, UnicodeDecodeError):
            continue
        # Check for CORS wildcard patterns
        if re.search(r'cors.*origin.*["\']\*["\']', content, re.IGNORECASE):
            rel_path = os.path.relpath(filepath, PROJECT_ROOT)
            violations.append(rel_path)
        if re.search(r'Access-Control-Allow-Origin["\s:]*\*', content):
            rel_path = os.path.relpath(filepath, PROJECT_ROOT)
            violations.append(rel_path)

    if violations:
        return ("No wildcard CORS", False, f"Found in: {', '.join(set(violations))}")
    return ("No wildcard CORS", True, None)


def check_required_files():
    """Verify key structural files exist."""
    required = [
        "directives/SOP.md",
        ".agent/readme.md",
        "tools/sync_configs.py",
        "tools/verify_{{DOMAIN}}.py",
    ]

    missing = []
    for rel_path in required:
        full_path = os.path.join(PROJECT_ROOT, rel_path)
        if not os.path.exists(full_path):
            missing.append(rel_path)

    if missing:
        return ("Required files exist", False, f"Missing: {', '.join(missing)}")
    return ("Required files exist", True, f"All {len(required)} files present")


def main():
    print("=" * 50)
    print("{{PROJECT_NAME}} — API Verification")
    print("Reference: directives/SOP.md")
    print("=" * 50)

    checks = [
        check_no_hardcoded_secrets(),
        check_no_sql_injection(),
        check_input_validation(),
        check_cors_not_wildcard(),
        check_required_files(),
    ]

    all_passed = True
    for name, passed, detail in checks:
        status = "PASS" if passed else "FAIL"
        icon = "[+]" if passed else "[!]"
        print(f"  {icon} {status}: {name}")
        if detail:
            print(f"         {detail}")
        if not passed:
            all_passed = False

    print("=" * 50)
    if all_passed:
        print("Result: ALL CHECKS PASSED")
        return 0
    else:
        print("Result: CHECKS FAILED — fix before completing task")
        return 1


if __name__ == "__main__":
    sys.exit(main())
