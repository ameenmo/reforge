#!/usr/bin/env python3
"""{{PROJECT_NAME}} agent verification checks.

Scans source files to verify that code adheres to project rules
defined in directives/SOP.md.

Exit codes:
    0 — All checks pass
    1 — One or more checks failed
"""

import os
import re
import sys

PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))


def scan_files(directory, extensions=(".py", ".ts", ".js")):
    """Yield all files with given extensions in directory recursively."""
    for root, _dirs, files in os.walk(directory):
        if "node_modules" in root or "__pycache__" in root or ".venv" in root or "dist" in root:
            continue
        for f in files:
            if any(f.endswith(ext) for ext in extensions):
                yield os.path.join(root, f)


def check_no_hardcoded_secrets():
    """Ensure no hardcoded API keys or secrets in source files."""
    secret_patterns = [
        (r'["\']sk-[a-zA-Z0-9]{20,}["\']', "OpenAI API key"),
        (r'["\']ghp_[a-zA-Z0-9]{36,}["\']', "GitHub personal access token"),
        (r'["\']Bearer\s+[a-zA-Z0-9._-]{20,}["\']', "Hardcoded Bearer token"),
        (r'password\s*[:=]\s*["\'][^"\']{8,}["\']', "Hardcoded password"),
        (r'api_key\s*[:=]\s*["\'][^"\']{8,}["\']', "Hardcoded API key"),
        (r'["\']AKIA[A-Z0-9]{16}["\']', "AWS access key"),
    ]

    violations = []
    for filepath in scan_files(PROJECT_ROOT):
        if "__tests__" in filepath or "test_" in os.path.basename(filepath) or "_test." in filepath:
            continue
        try:
            with open(filepath, encoding="utf-8") as f:
                content = f.read()
        except (OSError, UnicodeDecodeError):
            continue
        for pattern, desc in secret_patterns:
            matches = re.findall(pattern, content)
            for match in matches:
                rel_path = os.path.relpath(filepath, PROJECT_ROOT)
                violations.append(f"{rel_path}: {desc} found")

    if violations:
        detail = "; ".join(violations[:3])
        if len(violations) > 3:
            detail += f" (+{len(violations) - 3} more)"
        return ("No hardcoded secrets in source", False, detail)
    return ("No hardcoded secrets in source", True, None)


def check_config_from_env():
    """Ensure configuration values come from environment variables."""
    bad_patterns = [
        (r'api_key\s*=\s*["\'][^"\']+["\']', "Hardcoded API key assignment"),
        (r'base_url\s*=\s*["\']https?://[^"\']+["\']', "Hardcoded base URL"),
        (r'model\s*=\s*["\']gpt-[^"\']+["\']', "Hardcoded model name (use env/config)"),
    ]

    violations = []
    for filepath in scan_files(PROJECT_ROOT):
        if "test" in os.path.basename(filepath).lower() or "config" in os.path.basename(filepath).lower():
            continue
        try:
            with open(filepath, encoding="utf-8") as f:
                content = f.read()
        except (OSError, UnicodeDecodeError):
            continue
        for pattern, desc in bad_patterns:
            if re.search(pattern, content):
                rel_path = os.path.relpath(filepath, PROJECT_ROOT)
                violations.append(f"{rel_path}: {desc}")

    if violations:
        detail = "; ".join(violations[:3])
        return ("Config from env vars", False, detail)
    return ("Config from env vars", True, None)


def check_error_handling():
    """Check that tool/pipeline functions have try/except or error handling."""
    # This is a heuristic check — looks for bare raise or unhandled patterns
    violations = []
    for filepath in scan_files(PROJECT_ROOT, extensions=(".py",)):
        try:
            with open(filepath, encoding="utf-8") as f:
                content = f.read()
        except (OSError, UnicodeDecodeError):
            continue
        # Check for functions that call external APIs without try/except
        if "requests.get(" in content or "requests.post(" in content or "httpx." in content:
            if "try:" not in content and "except" not in content:
                rel_path = os.path.relpath(filepath, PROJECT_ROOT)
                violations.append(f"{rel_path}: HTTP calls without error handling")

    if violations:
        detail = "; ".join(violations[:3])
        return ("Error handling on external calls", False, detail)
    return ("Error handling on external calls", True, None)


def check_required_files():
    """Verify key structural files exist."""
    required = [
        "directives/SOP.md",
        ".agent/readme.md",
        "tools/sync_configs.py",
        "tools/verify_{{DOMAIN}}.py",
    ]

    missing = []
    for rel_path in required:
        full_path = os.path.join(PROJECT_ROOT, rel_path)
        if not os.path.exists(full_path):
            missing.append(rel_path)

    if missing:
        return ("Required files exist", False, f"Missing: {', '.join(missing)}")
    return ("Required files exist", True, f"All {len(required)} files present")


def main():
    print("=" * 50)
    print("{{PROJECT_NAME}} — Agent Verification")
    print("Reference: directives/SOP.md")
    print("=" * 50)

    checks = [
        check_no_hardcoded_secrets(),
        check_config_from_env(),
        check_error_handling(),
        check_required_files(),
    ]

    all_passed = True
    for name, passed, detail in checks:
        status = "PASS" if passed else "FAIL"
        icon = "[+]" if passed else "[!]"
        print(f"  {icon} {status}: {name}")
        if detail:
            print(f"         {detail}")
        if not passed:
            all_passed = False

    print("=" * 50)
    if all_passed:
        print("Result: ALL CHECKS PASSED")
        return 0
    else:
        print("Result: CHECKS FAILED — fix before completing task")
        return 1


if __name__ == "__main__":
    sys.exit(main())
